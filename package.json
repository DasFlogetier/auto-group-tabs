{
  "type": "module",
  "scripts": {
    "dev": "wireit",
    "dev:background": "wireit",
    "dev:test": "wireit",
    "build:options:chromium": "wireit",
    "build:options:gecko": "wireit",
    "build:background:chromium": "wireit",
    "build:background:gecko": "wireit",
    "build:manifest:chromium": "wireit",
    "build:manifest:gecko": "wireit",
    "test:types": "wireit",
    "test:lint": "wireit",
    "test:unit": "wireit",
    "test:browser": "wireit",
    "test": "wireit",
    "build:chromium": "wireit",
    "build:gecko": "wireit",
    "pack:chromium": "wireit",
    "pack:gecko": "wireit",
    "deploy": "wireit"
  },
  "wireit": {
    "dev": {
      "command": "vite -c vite.chromium.config.ts --host",
      "service": true,
      "files": [
        "src/**/*",
        "!src/node_modules",
        "vite.chromium.config.ts"
      ]
    },
    "dev:background": {
      "command": "rolldown -c rolldown-background.config.ts --watch",
      "service": true,
      "files": [
        "src/background.ts"
      ]
    },
    "dev:test": {
      "command": "vitest -c vite.chromium.config.ts",
      "service": true
    },
    "build:options:chromium": {
      "command": "vite -c vite.chromium.config.ts build",
      "files": [
        "src/**/*",
        "!src/node_modules",
        "static/**/*",
        "vite.chromium.config.ts"
      ],
      "output": [
        "extension-chromium",
        "!extension-chromium/manifest.json",
        "!extension-chromium/background.js"
      ]
    },
    "build:options:gecko": {
      "command": "vite -c vite.gecko.config.ts build",
      "files": [
        "src/**/*",
        "!src/node_modules",
        "static/**/*",
        "vite.gecko.config.ts"
      ],
      "output": [
        "extension-gecko",
        "!extension-gecko/manifest.json",
        "!extension-gecko/background.js"
      ]
    },
    "build:background:chromium": {
      "command": "rolldown -c rolldown-background.chromium.config.ts",
      "files": [
        "src/**/*",
        "!src/node_modules",
        "rolldown-background.config.ts"
      ],
      "output": [
        "extension-chromium/background.js"
      ],
      "dependencies": [
        "build:options:chromium"
      ]
    },
    "build:background:gecko": {
      "command": "rolldown -c rolldown-background.gecko.config.ts",
      "files": [
        "src/**/*",
        "!src/node_modules",
        "rolldown-background.config.ts"
      ],
      "output": [
        "extension-gecko/background.js"
      ],
      "dependencies": [
        "build:options:gecko"
      ]
    },
    "build:manifest:chromium": {
      "command": "node -e 'fs.writeFileSync(\"extension-chromium/manifest.json\", JSON.stringify((await import(\"./src/manifest/manifest.chromium.ts\")).default, null, 2))'",
      "files": [
        "src/**/*",
        "!src/node_modules"
      ],
      "output": [
        "extension-chromium/manifest.json"
      ],
      "dependencies": [
        "build:options:chromium"
      ]
    },
    "build:manifest:gecko": {
      "command": "node -e 'fs.writeFileSync(\"extension-gecko/manifest.json\", JSON.stringify((await import(\"./src/manifest/manifest.gecko.ts\")).default, null, 2))'",
      "files": [
        "src/**/*",
        "!src/node_modules"
      ],
      "output": [
        "extension-gecko/manifest.json"
      ],
      "dependencies": [
        "build:options:gecko"
      ]
    },
    "test:types": {
      "command": "vue-tsc --noEmit",
      "files": [
        "src/**/*",
        "!src/node_modules",
        "tsconfig.json",
        "tsconfig.node.json"
      ],
      "output": []
    },
    "test:lint": {
      "command": "oxlint src --type-aware",
      "files": [
        "src/**/*",
        "!src/node_modules",
        ".oxlintrc.json"
      ],
      "output": []
    },
    "test:unit": {
      "command": "vitest run -c vite.chromium.config.ts",
      "files": [
        "src/**/*",
        "!src/node_modules",
        "vite.chromium.config.ts"
      ],
      "output": [
        "src/node_modules/.vite/vitest"
      ]
    },
    "test:browser": {
      "command": "playwright test",
      "files": [
        "src/**/*",
        "!src/node_modules",
        "playwright.config.ts"
      ],
      "output": [
        "playwright-report",
        "test-results"
      ],
      "dependencies": [
        "dev"
      ]
    },
    "test": {
      "dependencies": [
        "test:types",
        "test:lint",
        "test:unit",
        "test:browser"
      ]
    },
    "build:chromium": {
      "dependencies": [
        "test",
        "build:options:chromium",
        "build:background:chromium",
        "build:manifest:chromium"
      ]
    },
    "build:gecko": {
      "dependencies": [
        "test",
        "build:options:gecko",
        "build:background:gecko",
        "build:manifest:gecko"
      ]
    },
    "pack:chromium": {
      "command": "node pack.ts chromium",
      "files": [
        "extension-chromium/**/*",
        "pack.ts"
      ],
      "output": [
        "auto-group-tabs.chromium.zip"
      ],
      "dependencies": [
        "build:chromium"
      ]
    },
    "pack:gecko": {
      "command": "node pack.ts gecko",
      "files": [
        "extension-gecko/**/*",
        "pack.ts"
      ],
      "output": [
        "auto-group-tabs.gecko.zip"
      ],
      "dependencies": [
        "build:gecko"
      ]
    },
    "deploy": {
      "dependencies": [
        "pack:chromium",
        "pack:gecko"
      ]
    }
  },
  "dependencies": {
    "@babel/types": "^7.28.5",
    "@vueuse/core": "^14.1.0",
    "@vueuse/shared": "^14.1.0",
    "destr": "^2.0.5",
    "gsap": "^3.14.2",
    "monomitter": "^2.0.0",
    "php-date": "^4.0.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.26",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.11.5",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@mdi/font": "^7.4.47",
    "@playwright/test": "^1.57.0",
    "@types/archiver": "^7.0.0",
    "@types/chrome": "^0.1.32",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/compiler-sfc": "^3.5.26",
    "archiver": "^7.0.1",
    "oxlint": "^1.35.0",
    "oxlint-tsgolint": "^0.10.0",
    "rolldown": "^1.0.0-beta.57",
    "type-fest": "^5.3.1",
    "typescript": "^5.9.3",
    "vite": "npm:rolldown-vite@latest",
    "vite-plugin-static-copy": "^3.1.4",
    "vite-plugin-vuetify": "^2.1.2",
    "vitest": "^4.0.16",
    "vue-tsc": "^3.2.1",
    "wireit": "^0.14.12"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
